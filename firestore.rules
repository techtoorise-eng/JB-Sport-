rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Booking lead rules
    match /bookings/{bookingId} {
      // Anyone can submit a booking request (needed for public booking submissions)
      allow create: if request.resource.data.parentName != null &&
                    request.resource.data.parentPhone != null &&
                    request.resource.data.preferredSport != null;
                    
      // Only authenticated team/academy admins can read, update, or delete leads
      allow read, update, delete: if request.auth != null;
    }
    
    // Sheet synchronization setting rules
    match /settings/{settingId} {
      // Allow read access for active sync details (allows dashboard initialization)
      allow read: if true;
      
      // Only authenticated workspace coordinators can create or modify synchronization targets
      allow write: if request.auth != null;
    }
  }
}
